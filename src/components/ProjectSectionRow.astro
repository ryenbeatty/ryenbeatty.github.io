---
import Media from './Media/index.svelte'

interface MediaItem {
  src: string
  type: 'image' | 'video' | 'vidstack'
  alt?: string
  poster?: string
}

interface Props {
  /** Rendered HTML for the sticky left column */
  bodyHtml: string
  media: MediaItem[]
  /** Heading above body (e.g. project title) */
  title?: string
  /** When set, title is rendered as a link (e.g. for homepage index) */
  titleHref?: string
}

const { bodyHtml, media, title, titleHref } = Astro.props
---

<div class="project-section-row">
  <div class="project-section-row__text">
    {title && (
      titleHref ? (
        <h2 class="project-section-row__title">
          <a href={titleHref} class="project-section-row__title-link">{title}</a>
        </h2>
      ) : (
        <h2 class="project-section-row__title">{title}</h2>
      )
    )}
    <div
      class="project-section-row__body prose dark:prose-invert"
      set:html={bodyHtml}
    />
  </div>
  <div class="project-section-row__media">
    {
      media.map((item) => {
        if (item.type === 'video') {
          return (
            <video
              src={item.src}
              autoplay
              loop
              muted
              playsinline
              class="project-section-row__asset project-section-row__video--ambient"
              aria-label={item.alt}
            />
          )
        }
        if (item.type === 'vidstack') {
          return (
            <div class="project-section-row__embed-wrap project-section-row__vidstack-wrap">
              <Media
                client:only="svelte"
                viewType="video"
                src={item.src}
                title={item.alt ?? 'Video'}
                poster={item.poster ?? ''}
                posterAlt={item.alt ?? ''}
              />
            </div>
          )
        }
        return (
          <img
            src={item.src}
            alt={item.alt ?? ''}
            loading="lazy"
            class="project-section-row__asset"
          />
        )
      })
    }
  </div>
</div>

<style>
  .project-section-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    align-items: start;
    padding: 2rem 0;
  }

  .project-section-row__text {
    grid-column: span 4;
    position: sticky;
    top: 2rem;
  }

  .project-section-row__title {
    margin: 0 0 0.5em;
    font-size: var(--step-1);
    font-weight: 500;
  }

  .project-section-row__title-link {
    color: inherit;
    text-decoration: none;
  }

  .project-section-row__title-link:hover {
    text-decoration: underline;
  }

  .project-section-row__body {
    margin: 0;
  }

  .project-section-row__body :global(p:first-child) {
    margin-top: 0;
  }

  .project-section-row__media {
    grid-column: span 8;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-section-row__asset {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.25rem;
  }

  .project-section-row__asset video {
    width: 100%;
    height: auto;
  }

  .project-section-row__video--ambient {
    pointer-events: none;
  }

  .project-section-row__embed-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.25rem;
    overflow: hidden;
  }

  .project-section-row__vidstack-wrap {
    aspect-ratio: 16 / 9;
    min-height: 200px;
  }

  .project-section-row__vidstack-wrap :global(.player) {
    width: 100%;
    height: 100%;
    min-height: inherit;
  }

  .project-section-row__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 768px) {
    .project-section-row {
      grid-template-columns: 1fr;
    }

    .project-section-row__text {
      position: static;
    }

    .project-section-row__media {
      order: 2;
    }
  }
</style>
