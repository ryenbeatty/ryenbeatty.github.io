---
import Media from './Media/index.svelte'

interface MediaItem {
  src: string
  type: 'image' | 'video' | 'vidstack'
  alt?: string
  poster?: string
  /** CSS pixel width; use maxWidthPx if width is missing after build */
  width?: number
  maxWidthPx?: number
}

interface Props {
  /** Rendered HTML for the sticky left column */
  bodyHtml: string
  media: MediaItem[]
  /** Heading above body (e.g. project title) */
  title?: string
  /** When set, title is rendered as a link (e.g. for homepage index) */
  titleHref?: string
}

const { bodyHtml, media, title, titleHref } = Astro.props

function mediaSizingStyle(width: number | undefined): string | undefined {
  if (width == null) return undefined
  return `width:${width}px;max-width:100%;height:auto;`
}

function resolveMediaWidth(item: MediaItem): number | undefined {
  return item.maxWidthPx ?? item.width
}
---


<div class="project-section-row">
  <div class="project-section-row__text">
    {title && (
      titleHref ? (
        <h2 class="project-section-row__title">
          <a href={titleHref} class="project-section-row__title-link">{title}</a>
        </h2>
      ) : (
        <h2 class="project-section-row__title">{title}</h2>
      )
    )}
    <div
      class="project-section-row__body prose dark:prose-invert"
      set:html={bodyHtml}
    />
  </div>
  <div class="project-section-row__media">
    {
      media.map((item) => {
        const w = resolveMediaWidth(item)
        if (item.type === 'video') {
          return (
            <video
              src={item.src}
              autoplay
              loop
              muted
              playsinline
              class:list={[
                'project-section-row__asset',
                'project-section-row__video--ambient',
                { 'project-section-row__asset--sized': w != null },
              ]}
              aria-label={item.alt}
              width={w}
              style={mediaSizingStyle(w)}
            />
          )
        }
        if (item.type === 'vidstack') {
          return (
            <div
              class:list={[
                'project-section-row__embed-wrap',
                'project-section-row__vidstack-wrap',
                { 'project-section-row__embed-wrap--sized': w != null },
              ]}
              style={
                w != null
                  ? `max-width:${w}px;width:100%;`
                  : undefined
              }
            >
              <Media
                client:only="svelte"
                viewType="video"
                src={item.src}
                title={item.alt ?? 'Video'}
                poster={item.poster ?? ''}
                posterAlt={item.alt ?? ''}
              />
            </div>
          )
        }
        return (
          <img
            src={item.src}
            alt={item.alt ?? ''}
            loading="lazy"
            class:list={[
              'project-section-row__asset',
              { 'project-section-row__asset--sized': w != null },
            ]}
            width={w}
            style={mediaSizingStyle(w)}
          />
        )
      })
    }
  </div>
</div>

<style>
  .project-section-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    align-items: start;
    padding: 2rem 0;
  }

  .project-section-row__text {
    grid-column: span 4;
    position: sticky;
    top: 2rem;
  }

  .project-section-row__title {
    margin: 0 0 0.4em;
    font-size: var(--step-0);
    font-weight: 500;
  }

  .project-section-row__title-link {
    color: inherit;
    text-decoration: none;
  }

  .project-section-row__title-link:hover {
    text-decoration: underline;
  }

  .project-section-row__body {
    margin: 0;
  }

  .project-section-row__body :global(p:first-child) {
    margin-top: 0;
  }

  .project-section-row__media {
    grid-column: span 8;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .project-section-row__asset {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: 0.25rem;
  }

  /* Explicit width in frontmatter: opt out of flex cross-axis stretch */
  .project-section-row__asset--sized {
    align-self: flex-start;
    flex-shrink: 0;
  }

  .project-section-row__asset video {
    width: 100%;
    height: auto;
  }

  .project-section-row__video--ambient {
    pointer-events: none;
  }

  .project-section-row__embed-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.25rem;
    overflow: hidden;
  }

  .project-section-row__embed-wrap--sized {
    align-self: flex-start;
  }

  .project-section-row__vidstack-wrap {
    aspect-ratio: 16 / 9;
    min-height: 200px;
  }

  .project-section-row__vidstack-wrap :global(.player) {
    width: 100%;
    height: 100%;
    min-height: inherit;
  }

  .project-section-row__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 768px) {
    .project-section-row {
      grid-template-columns: 1fr;
    }

    .project-section-row__text {
      position: static;
    }

    .project-section-row__media {
      order: 2;
    }
  }
</style>
