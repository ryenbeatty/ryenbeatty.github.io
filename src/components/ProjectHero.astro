---
interface Props {
  description: string
  headerBackground?: string
  heroImage?: string
}

const { description, headerBackground, heroImage } = Astro.props
---

<section class="hero" id="project-hero">
  {
    headerBackground && (
      <div class="backgroundLayer" id="hero-background-layer">
        <img class="backgroundImage" src={headerBackground} alt="" />
        <div class="backgroundOverlay" aria-hidden="true" />
      </div>
    )
  }
  <div class="contentLayer">
    <p class="heroTitle">{description}</p>
    {
      heroImage && (
        <div class="mockupWrapper" id="hero-mockup">
          <div class="mockupContainer">
            <img class="mockupImage" src={heroImage} alt="" />
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    min-height: 90vh;
    max-height: 90vh;
    overflow: clip;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: 120px;
    padding-bottom: 2rem;
    border-radius: 0 0 46px 46px;
    background-color: var(--wash-color, #e5e5e5);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .hero.visible {
    opacity: 1;
  }

  .backgroundLayer {
    position: absolute;
    inset: -10% 0;
    width: 100%;
    height: 120%;
    z-index: 0;
    will-change: transform;
  }

  .backgroundImage {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    position: absolute;
    inset: 0;
  }

  .backgroundOverlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
    pointer-events: none;
  }

  .contentLayer {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .heroTitle {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 500;
    line-height: 1.3;
    text-align: center;
    color: #fff;
    text-shadow: rgba(0, 0, 0, 0.08) 0 2px 8px;
    max-width: 800px;
    will-change: transform, opacity;
    transform: translateZ(0);
    position: relative;
    z-index: 1;
  }

  .mockupWrapper {
    width: 100%;
    padding-top: 1rem;
    will-change: transform;
    transform: translateZ(0);
    position: relative;
    z-index: 2;
  }

  .mockupContainer {
    width: 100%;
  }

  .mockupImage {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes zoomOut {
    from {
      transform: scale(1.1);
    }
    to {
      transform: scale(1);
    }
  }

  .hero.visible .heroTitle {
    animation: fadeIn 0.8s ease-out 0.1s 1 forwards;
    opacity: 0;
  }

  .hero.visible .mockupWrapper {
    animation: fadeIn 0.5s ease-out 0.3s 1 forwards;
    opacity: 0;
  }

  .hero.visible .backgroundLayer {
    animation: zoomOut 0.6s ease-out 0s 1 forwards;
  }
</style>

<script>
  function initHeroParallax() {
    const hero = document.getElementById('project-hero')
    const backgroundLayer = document.getElementById('hero-background-layer')
    const mockupWrapper = document.getElementById('hero-mockup')

    if (!hero) return

    hero.classList.add('visible')

    let ticking = false
    function updateParallax() {
      const scrollY = window.scrollY
      if (backgroundLayer) {
        backgroundLayer.style.transform = `scale(1) translate3d(0px, ${scrollY * 0.3}px, 0px)`
      }
      if (mockupWrapper) {
        mockupWrapper.style.transform = `translate3d(0px, ${scrollY * -0.6}px, 0px)`
      }
      ticking = false
    }

    function onScroll() {
      if (ticking) return
      ticking = true
      requestAnimationFrame(updateParallax)
    }

    window.addEventListener('scroll', onScroll, { passive: true })

    // Initial state after entry animation
    setTimeout(() => requestAnimationFrame(updateParallax), 700)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroParallax)
  } else {
    initHeroParallax()
  }
</script>
