---
import clsx from 'clsx'

interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'ghost'
  size?: 'sm' | 'md'
  type?: 'button' | 'submit' | 'reset'
  class?: string
  target?: string
  rel?: string
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className,
  target,
  rel,
  ...rest
} = Astro.props

const classes = clsx('btn', `btn--${variant}`, `btn--${size}`, className)

const isExternal =
  href != null && (target === '_blank' || /^https?:\/\//.test(href))
const linkRel = rel ?? (isExternal ? 'noopener noreferrer' : undefined)
---

{
  href ? (
    <a href={href} class={classes} target={target} rel={linkRel} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
    font-family: var(--font-ui);
    font-weight: 400;
    line-height: 1.2;
    text-decoration: none;
    border-radius: 0.25rem;
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .btn--md {
    padding: 0.55em 1.1em;
    font-size: var(--step--1);
  }

  .btn--sm {
    padding: 0.4em 0.85em;
    font-size: var(--step--2);
  }

  .btn--primary {
    background-color: var(--site-color);
    color: var(--wash-color);
    border-color: var(--site-color);
  }

  .btn--primary:hover {
    opacity: 0.92;
  }

  .btn--secondary {
    background-color: transparent;
    color: var(--text-color);
    border-color: var(--gray20);
  }

  .btn--secondary:hover {
    border-color: var(--site-color);
    color: var(--site-color);
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--text-color);
    border-color: transparent;
    padding-inline: 0.35em;
  }

  .btn--ghost:hover {
    color: var(--site-color);
  }

  .btn:disabled,
  .btn[aria-disabled='true'] {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
