---
import Media from './Media/index.svelte'

interface MediaItem {
  src: string
  type: 'image' | 'video' | 'loom' | 'vidstack'
  alt?: string
  poster?: string
}

function loomEmbedUrl(shareOrEmbedUrl: string): string {
  let url = shareOrEmbedUrl.includes('/embed/')
    ? shareOrEmbedUrl
    : shareOrEmbedUrl.replace('/share/', '/embed/')
  const sep = url.includes('?') ? '&' : '?'
  // Hide chrome; autoplay + muted (muted required for autoplay in most browsers)
  url += `${sep}hideEmbedTopBar=true&hide_title=true&hide_owner=true&hide_share=true&autoplay=1&muted=1`
  return url
}

interface Props {
  /** Rendered HTML for the sticky left column */
  bodyHtml: string
  media: MediaItem[]
  /** If set, show as heading above body (e.g. project title for first row) */
  title?: string
}

const { bodyHtml, media, title } = Astro.props
---

<div class="section-row">
  <div class="section-row__text">
    {title && <h2 class="section-row__title">{title}</h2>}
    <div
      class="section-row__body prose dark:prose-invert"
      set:html={bodyHtml}
    />
  </div>
  <div class="section-row__media">
    {
      media.map((item) => {
        if (item.type === 'video') {
          return (
            <video
              src={item.src}
              autoplay
              loop
              muted
              playsinline
              class="section-row__asset section-row__video--ambient"
              aria-label={item.alt}
            />
          )
        }
        if (item.type === 'loom') {
          const embedSrc = loomEmbedUrl(item.src)
          return (
            <div class="section-row__embed-wrap">
              <iframe
                src={embedSrc}
                title={item.alt ?? 'Loom video'}
                class="section-row__asset section-row__embed"
                allowfullscreen
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              />
            </div>
          )
        }
        if (item.type === 'vidstack') {
          return (
            <div class="section-row__embed-wrap section-row__vidstack-wrap">
              <Media
                client:only="svelte"
                viewType="video"
                src={item.src}
                title={item.alt ?? 'Video'}
                poster={item.poster ?? ''}
                posterAlt={item.alt ?? ''}
              />
            </div>
          )
        }
        return (
          <img
            src={item.src}
            alt={item.alt ?? ''}
            loading="lazy"
            class="section-row__asset"
          />
        )
      })
    }
  </div>
</div>

<style>
  .section-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    align-items: start;
    padding: 2rem 0;
  }

  .section-row__text {
    grid-column: span 4;
    position: sticky;
    top: 2rem;
  }

  .section-row__title {
    margin: 0 0 0.5em;
    font-size: var(--step-1);
    font-weight: 500;
  }

  .section-row__body {
    margin: 0;
  }

  .section-row__body :global(p:first-child) {
    margin-top: 0;
  }

  .section-row__media {
    grid-column: span 8;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-row__asset {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.25rem;
  }

  .section-row__asset video {
    width: 100%;
    height: auto;
  }

  /* Autoplay, loop, no controls: prevent click from pausing */
  .section-row__video--ambient {
    pointer-events: none;
  }

  .section-row__embed-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.25rem;
    overflow: hidden;
  }

  .section-row__vidstack-wrap {
    aspect-ratio: 16 / 9;
    min-height: 200px;
  }

  .section-row__vidstack-wrap :global(.player) {
    width: 100%;
    height: 100%;
    min-height: inherit;
  }

  .section-row__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Stack on mobile/tablet */
  @media (max-width: 768px) {
    .section-row {
      grid-template-columns: 1fr;
    }

    .section-row__text {
      position: static;
    }

    .section-row__media {
      order: 2;
    }
  }
</style>
