---
interface Props {
  href: string
  title: string
  thumbnail?: string
  /** 'right' = next project (default); 'left' = previous project (e.g. when this is the last) */
  side?: 'left' | 'right'
}

const { href, title, thumbnail, side = 'right' } = Astro.props
const isLeft = side === 'left'
---

<aside
  class="next-project-nav"
  data-side={side}
  aria-label={isLeft ? 'Previous project' : 'Next project'}
>
  <a href={href} class="next-project-nav__link" data-astro-prefetch="hover">
    {isLeft && (
      <span class="next-project-nav__arrow" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
      </span>
    )}
    <span class="next-project-nav__tab">
      {thumbnail && (
        <span class="next-project-nav__thumb">
          <img src={thumbnail} alt="" width="56" height="56" />
        </span>
      )}
      <span class="next-project-nav__title">{title}</span>
    </span>
    {!isLeft && (
      <span class="next-project-nav__arrow" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </span>
    )}
  </a>
</aside>

<style>
  .next-project-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    --offset: 0.75rem;
  }

  .next-project-nav[data-side='right'] {
    right: 0;
    right: var(--offset);
  }

  .next-project-nav[data-side='left'] {
    left: 0;
    left: var(--offset);
  }

  .next-project-nav__link {
    display: flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    color: var(--text-color);
    background: var(--wash-color);
    border: 1px solid var(--color-border, rgba(0, 0, 0, 0.08));
    box-shadow: 0 0 12px rgba(0, 0, 0, 0.06);
    padding: 0.5rem;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .next-project-nav[data-side='right'] .next-project-nav__link {
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow: -4px 0 12px rgba(0, 0, 0, 0.06);
    padding: 0.5rem 0.5rem 0.5rem 0;
  }

  .next-project-nav[data-side='left'] .next-project-nav__link {
    border-left: none;
    border-radius: 0 8px 8px 0;
    box-shadow: 4px 0 12px rgba(0, 0, 0, 0.06);
    padding: 0.5rem 0 0.5rem 0.5rem;
  }

  .next-project-nav__link:hover {
    box-shadow: -6px 0 16px rgba(0, 0, 0, 0.1);
  }

  .next-project-nav[data-side='left'] .next-project-nav__link:hover {
    box-shadow: 6px 0 16px rgba(0, 0, 0, 0.1);
  }

  .next-project-nav__tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: max-width 0.25s ease;
  }

  .next-project-nav[data-side='left'] .next-project-nav__tab {
    flex-direction: row-reverse;
  }

  .next-project-nav[data-side='right'] .next-project-nav__link:hover .next-project-nav__tab {
    max-width: 220px;
  }

  .next-project-nav[data-side='left'] .next-project-nav__link:hover .next-project-nav__tab {
    max-width: 220px;
  }

  .next-project-nav__thumb {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--gray10, #eee);
  }

  .next-project-nav__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .next-project-nav__title {
    font-size: var(--step--2, 0.8rem);
    font-weight: 500;
    padding-right: 0.25rem;
  }

  .next-project-nav[data-side='left'] .next-project-nav__title {
    padding-right: 0;
    padding-left: 0.25rem;
  }

  .next-project-nav__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
  }

  .next-project-nav__arrow svg {
    display: block;
  }
</style>
