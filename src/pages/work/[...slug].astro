---
import Layout from 'layouts/Primary.astro'
import ProtectedLayout from 'layouts/Protected.astro'

import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const content = await getCollection('project')
  return content.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await entry.render()

const pageTitle = `${entry.data.title} Case Study`
const frontmatter = { ...entry.data, title: pageTitle }
---

<style>
  .project-header {
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }
</style>

{
  entry.data.password ? (
    <ProtectedLayout password={entry.data.password} storageKey={entry.slug}>
      <Layout frontmatter={frontmatter}>
        <header
          class="project-header relative flex min-h-[40vh] w-full flex-col items-center justify-center gap-6 bg-gray-200 bg-cover bg-center py-12 dark:bg-gray-800"
          style={entry.data['header-background'] ? { backgroundImage: `url(${entry.data['header-background']})` } : undefined}
        >
          <div class="absolute inset-0 bg-black/30 dark:bg-black/40" aria-hidden="true" />
          <p class="relative z-10 max-w-2xl px-6 text-center text-xl font-medium text-white drop-shadow-md md:text-2xl">
            {entry.data.description}
          </p>
          {entry.data['hero-image'] && (
            <div class="relative z-10 w-full max-w-3xl px-4">
              <img
                src={entry.data['hero-image']}
                alt=""
                class="max-h-[50vh] w-full object-contain object-center"
              />
            </div>
          )}
        </header>

        <div class="max-w-3xl mx-auto px-4 py-8">
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <Content />
          </div>
        </div>
      </Layout>
    </ProtectedLayout>
  ) : (
    <Layout frontmatter={frontmatter}>
      <header
        class="project-header relative flex min-h-[40vh] w-full flex-col items-center justify-center gap-6 bg-gray-200 bg-cover bg-center py-12 dark:bg-gray-800"
        style={entry.data['header-background'] ? { backgroundImage: `url(${entry.data['header-background']})` } : undefined}
      >
        <div class="absolute inset-0 bg-black/30 dark:bg-black/40" aria-hidden="true" />
        <p class="relative z-10 max-w-2xl px-6 text-center text-xl font-medium text-white drop-shadow-md md:text-2xl">
          {entry.data.description}
        </p>
        {entry.data['hero-image'] && (
          <div class="relative z-10 w-full max-w-3xl px-4">
            <img
              src={entry.data['hero-image']}
              alt=""
              class="max-h-[50vh] w-full object-contain object-center"
            />
          </div>
        )}
      </header>

      <div class="max-w-3xl mx-auto px-4 py-8">
        <div class="prose prose-lg dark:prose-invert max-w-none">
          <Content />
        </div>
      </div>
    </Layout>
  )
}
