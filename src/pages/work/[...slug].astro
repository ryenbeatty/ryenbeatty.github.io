---
import NextProjectNav from 'components/NextProjectNav.astro'
import ProjectHero from 'components/ProjectHero.astro'
import ProjectSectionRow from 'components/ProjectSectionRow.astro'
import Layout from 'layouts/Primary.astro'
import ProtectedLayout from 'layouts/Protected.astro'

import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import { marked } from 'marked'

export async function getStaticPaths() {
  const content = await getCollection('project')
  return content.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const allProjects = await getCollection('project')
const sorted = [...allProjects].sort(
  (a: CollectionEntry<'project'>, b: CollectionEntry<'project'>) => {
    const orderA = a.data.order ?? 999
    const orderB = b.data.order ?? 999
    if (orderA !== orderB) return orderA - orderB
    return b.data.date.getTime() - a.data.date.getTime()
  },
)
const currentIndex = sorted.findIndex((p) => p.slug === entry.slug)
const nextProject =
  currentIndex >= 0 && currentIndex < sorted.length - 1
    ? sorted[currentIndex + 1]
    : null
const prevProject = currentIndex > 0 ? sorted[currentIndex - 1] : null
const sections = entry.data.sections ?? []
const desc = entry.data.description
const firstBodyHtml =
  typeof desc === 'string' ? await Promise.resolve(marked(desc)) : String(desc)
const restRows = await Promise.all(
  sections.slice(1).map(async (sec) => ({
    bodyHtml:
      typeof sec.text === 'string'
        ? ((await Promise.resolve(marked(sec.text))) as string)
        : String(sec.text),
    media: sec.media,
  })),
)
interface SectionRowProps {
  title?: string
  bodyHtml: string
  media: {
    src: string
    type: 'image' | 'video' | 'vidstack'
    alt?: string
    poster?: string
  }[]
}
const sectionRows: SectionRowProps[] = [
  {
    title: entry.data.title,
    bodyHtml: firstBodyHtml as string,
    media: sections[0]?.media ?? [],
  },
  ...restRows,
]

const pageTitle = `${entry.data.title} 〰︎ Ryen Beatty 〰︎ Design engineer`
const frontmatter = { ...entry.data, title: pageTitle }
---

{
  entry.data.password ? (
    <ProtectedLayout password={entry.data.password} storageKey={entry.slug}>
      <Layout frontmatter={frontmatter}>
        <ProjectHero
          description={entry.data.description}
          headerBackground={entry.data['header-background']}
          heroImage={entry.data['hero-image']}
        />

        <div class="project-sections">
          {sectionRows.map((row) => (
            <ProjectSectionRow
              title={row.title}
              bodyHtml={row.bodyHtml}
              media={row.media}
            />
          ))}
        </div>
        {nextProject ? (
          <NextProjectNav
            href={`/work/${nextProject.slug}`}
            title={nextProject.data.title}
            thumbnail={nextProject.data.thumbnail}
            side="right"
          />
        ) : prevProject ? (
          <NextProjectNav
            href={`/work/${prevProject.slug}`}
            title={prevProject.data.title}
            thumbnail={prevProject.data.thumbnail}
            side="left"
          />
        ) : null}
      </Layout>
    </ProtectedLayout>
  ) : (
    <Layout frontmatter={frontmatter}>
      <ProjectHero
        description={entry.data.description}
        headerBackground={entry.data['header-background']}
        heroImage={entry.data['hero-image']}
      />

      <div class="project-sections">
        {sectionRows.map((row) => (
          <ProjectSectionRow
            title={row.title}
            bodyHtml={row.bodyHtml}
            media={row.media}
          />
        ))}
      </div>
      {nextProject ? (
        <NextProjectNav
          href={`/work/${nextProject.slug}`}
          title={nextProject.data.title}
          thumbnail={nextProject.data.thumbnail}
          side="right"
        />
      ) : prevProject ? (
        <NextProjectNav
          href={`/work/${prevProject.slug}`}
          title={prevProject.data.title}
          thumbnail={prevProject.data.thumbnail}
          side="left"
        />
      ) : null}
    </Layout>
  )
}
